@inherits LayoutComponentBase

<div data-theme="@(IsDarkTheme ? "dark" : "light")">
    <!-- LOADING TOÀN CỤC -->
    @if (IsLoading)
    {
        <div class="loading">
            <div class="loader-wrapper">
                <img src="/image/loading.gif" class="loader" />
                <div class="road"></div>
            </div>
        </div>
    }

    <!-- THÔNG BÁO TOÀN CỤC -->
    <div class="toast-container">
        @foreach (var toast in Toasts)
        {
            <div class="toast toast-@toast.Type.ToString().ToLower() @(toast.IsVisible ? "show" : "")"
                 style="animation-delay: @(toast.Index * 0.1)s">
                <div class="toast-icon">
                    @switch (toast.Type)
                    {
                        case ToastType.Success:
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path d="M20 6L9 17l-5-5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            break;
                        case ToastType.Error:
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <circle cx="12" cy="12" r="10" stroke-width="2" />
                                <line x1="15" y1="9" x2="9" y2="15" stroke-width="2" stroke-linecap="round" />
                                <line x1="9" y1="9" x2="15" y2="15" stroke-width="2" stroke-linecap="round" />
                            </svg>
                            break;
                        case ToastType.Warning:
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path d="M12 2L2 20h20L12 2z" stroke-width="2" stroke-linejoin="round" />
                                <line x1="12" y1="9" x2="12" y2="13" stroke-width="2" stroke-linecap="round" />
                                <circle cx="12" cy="17" r="1" fill="currentColor" />
                            </svg>
                            break;
                        case ToastType.Info:
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <circle cx="12" cy="12" r="10" stroke-width="2" />
                                <line x1="12" y1="16" x2="12" y2="12" stroke-width="2" stroke-linecap="round" />
                                <circle cx="12" cy="8" r="1" fill="currentColor" />
                            </svg>
                            break;
                    }
                </div>
                <div class="toast-content">
                    @if (!string.IsNullOrEmpty(toast.Title))
                    {
                        <div class="toast-title">@toast.Title</div>
                    }
                    <div class="toast-message">@toast.Message</div>
                </div>
                <button class="toast-close" @onclick="() => RemoveToast(toast.Id)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <line x1="18" y1="6" x2="6" y2="18" stroke-width="2" stroke-linecap="round" />
                        <line x1="6" y1="6" x2="18" y2="18" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </button>
            </div>
        }
    </div>

    <CascadingValue Value="this">
        <div class="app-shell @(SidebarCollapsed ? "sidebar-collapsed" : string.Empty)">
            <NavMenu />

            <div class="app-content">
                <Header />
                <!-- PAGE -->
                <main class="page-main">
                    @Body
                </main>
                <Footer />

            </div>
        </div>
    </CascadingValue>

</div>

@code {
    public bool IsLoading { get; set; }
    public bool SidebarCollapsed { get; set; }
    public bool IsDarkTheme { get; set; }

    private List<ToastNotification> Toasts { get; set; } = new();
    private int _toastCounter = 0;

    public void ShowLoading()
    {
        IsLoading = true;
        StateHasChanged();
    }

    public void HideLoading()
    {
        IsLoading = false;
        StateHasChanged();
    }

    public void ToggleSidebar()
    {
        SidebarCollapsed = !SidebarCollapsed;
        StateHasChanged();
    }

    public void ToggleTheme()
    {
        IsDarkTheme = !IsDarkTheme;
        StateHasChanged();
    }

    // Toast methods
    public void ShowToast(string message, ToastType type = ToastType.Info, string? title = null, int durationMs = 5000)
    {
        var toast = new ToastNotification
        {
            Id = ++_toastCounter,
            Index = Toasts.Count,
            Message = message,
            Type = type,
            Title = title,
            IsVisible = false
        };

        Toasts.Add(toast);
        StateHasChanged();

        // Trigger animation
        _ = Task.Run(async () =>
        {
            // Hiện toast
            await Task.Delay(50);
            toast.IsVisible = true;
            await InvokeAsync(StateHasChanged);

            // Đợi 5 giây (hoặc durationMs)
            await Task.Delay(durationMs);

            // Ẩn toast với animation
            toast.IsVisible = false;
            await InvokeAsync(StateHasChanged);

            // Đợi animation chạy xong (300ms) rồi mới xóa khỏi danh sách
            await Task.Delay(300);
            Toasts.Remove(toast);
            await InvokeAsync(StateHasChanged);
        });
    }

    public void ShowSuccess(string message, string? title = null) => ShowToast(message, ToastType.Success, title ?? "Thành công");
    public void ShowError(string message, string? title = null) => ShowToast(message, ToastType.Error, title ?? "Lỗi");
    public void ShowWarning(string message, string? title = null) => ShowToast(message, ToastType.Warning, title ?? "Cảnh báo");
    public void ShowInfo(string message, string? title = null) => ShowToast(message, ToastType.Info, title);

    private void RemoveToast(int id)
    {
        var toast = Toasts.FirstOrDefault(t => t.Id == id);
        if (toast != null)
        {
            toast.IsVisible = false;
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                await Task.Delay(300); // Đợi animation
                Toasts.Remove(toast);
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    public enum ToastType
    {
        Success,
        Error,
        Warning,
        Info
    }

    private class ToastNotification
    {
        public int Id { get; set; }
        public int Index { get; set; }
        public string Message { get; set; } = string.Empty;
        public string? Title { get; set; }
        public ToastType Type { get; set; }
        public bool IsVisible { get; set; }
    }
}
