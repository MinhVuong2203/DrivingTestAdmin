@page "/users"

@inject HttpClient Http
@using Frontend.Components.Layout
@using Frontend.Models
@inject IJSRuntime JS

<link href="/css/user/list-user.css" rel="stylesheet" />

<h3 class="page-title">Quản lý người dùng</h3>

<div class="">

    <div class="toolbar">

        <div class="toolbar-left">
            <input placeholder="Tìm kiếm..."
                   @bind="searchText"
                   @bind:event="oninput" />

            <select @bind="quickFilter" @bind:after="ApplyQuickFilter">
                <option value="">Tất cả</option>
                <option value="week">Tuần này</option>
                <option value="month">Tháng này</option>
                <option value="year">Năm nay</option>
            </select>
        </div>

        <div class="toolbar-right">
            <div class="view-toggle">
                <i class="bi bi-table @(viewMode == "table" ? "active" : "")"
                   @onclick='() => viewMode = "table"'></i>

                <i class="bi bi-grid @(viewMode == "card" ? "active" : "")"
                   @onclick='() => viewMode = "card"'></i>
            </div>
        </div>

    </div>

    <!-- TABLE -->
    @if (viewMode == "table")
    {
        <table class="table">
            <thead>
                <tr>
  
                    <th @onclick='() => Sort("displayName")'>
                        Người dùng
                        <i class="@GetSortIcon("displayName")"></i>
                    </th>

                    <th @onclick='() => Sort("email")'>
                        Email
                        <i class="@GetSortIcon("email")"></i>
                    </th>

                    <th @onclick='() => Sort("createdAt")'>
                        Ngày tạo
                        <i class="@GetSortIcon("createdAt")"></i>
                    </th>

                    <th>VIP</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var u in pagedUsers)
                {
                    <tr>
                        <!-- AVATAR -->
                        <td>
                            <div class="user-css">
                                <div class="avatar-wrapper">
                                    @if (!string.IsNullOrEmpty(u.photoURL) && !errorImages.Contains(u.uid))
                                    {
                                        <img src="@u.photoURL"
                                             class="avatar"
                                             @onerror="() => OnImageError(u.uid)" />
                                    }
                                    else
                                    {
                                        <div class="avatar-fallback">
                                            @GetInitial(u.displayName)
                                        </div>
                                    }
                                </div>
                                <div class="user-display">@u.displayName</div>
                            </div>      
                        </td>
                        <td>@u.email</td>
                        <td>@u.createdAt?.ToString("dd/MM/yyyy")</td>

                        <!-- VIP -->
                        <td>
                            @if (u.vipUser != null)
                            {
                                <span class="badge vip-badge">
                                    <i class="bi bi-star-fill"></i> @u.vipUser.name
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-gray">-</span>
                            }
                        </td>

                        <!-- STATUS -->
                        <td>
                            <span class="badge status-badge @(u.status == "active" ? "active" : "locked")">
                                <i class="bi @(u.status == "active" ? "bi-check-circle" : "bi-lock")"></i>
                                @u.status
                            </span>
                        </td>

                        <!-- ACTION -->
                        <td>
                            @if (u.status == "active")
                            {
                                <button class="btn-danger"
                                        @onclick='() => ConfirmToggleStatus(u, "locked")'>
                                    <i class="bi bi-lock"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn-success"
                                        @onclick='() => ConfirmToggleStatus(u, "active")'>
                                    <i class="bi bi-unlock"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- CARD -->
    @if (viewMode == "card")
    {
        <div class="card-grid">
            @foreach (var u in pagedUsers)
            {
                <div class="user-card">
                    <div class="avatar-wrapper">
                        @if (!string.IsNullOrEmpty(u.photoURL) && !errorImages.Contains(u.uid))
                        {
                            <img src="@u.photoURL"
                                 class="avatar"
                                 @onerror="() => OnImageError(u.uid)" />
                        }
                        else
                        {
                            <div class="avatar-fallback">
                                @GetInitial(u.displayName)
                            </div>
                        }
                    </div>

                    <h4>@u.displayName</h4>
                    <p>@u.email</p>

                    <span class="vip">@((u.vipUser?.name) ?? "-")</span>

                    <!-- ACTION -->
                    <div class="card-actions">
                        @if (u.status == "active")
                        {
                            <button class="btn-danger"
                                    @onclick='() => ConfirmToggleStatus(u, "locked")'>
                                <i class="bi bi-lock"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn-success"
                                    @onclick='() => ConfirmToggleStatus(u, "active")'>
                                <i class="bi bi-unlock"></i>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <!-- PAGINATION -->
    <div class="pagination">
        <button @onclick="PrevPage">Prev</button>
        <span>@currentPage / @totalPages</span>
        <button @onclick="NextPage">Next</button>
    </div>

</div>

@code {
    [CascadingParameter]
    public MainLayout Layout { get; set; }

    private List<User> users = new();

    private string searchText = "";
    private string viewMode = "table";
    private string quickFilter = "";

    private int currentPage = 1;
    private int pageSize = 10;

    private string sortField = "createdAt";
    private bool sortAsc = false;

    private DateTime? fromDate;
    private DateTime? toDate;

    private HashSet<string> errorImages = new();

    protected override async Task OnInitializedAsync()
    {
        Layout?.ShowLoading();   // bật loading
        try
        {
            users = await Http.GetFromJsonAsync<List<User>>("api/users") ?? new();
        }
        catch
        {
            Layout?.ShowError("Không tải được danh sách user");
        }
        finally
        {
            Layout?.HideLoading();  // tắt loading
        }
    }


    private void OnImageError(string uid)
    {
        errorImages.Add(uid);
    }

    private string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 1)
            return parts[0][0].ToString().ToUpper();

        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    private string GetSortIcon(string field)
    {
        if (sortField != field)
            return "bi bi-arrow-down-up sort-icon";

        return sortAsc
            ? "bi bi-arrow-up sort-icon active"
            : "bi bi-arrow-down sort-icon active";
    }

    private IEnumerable<User> processedUsers =>
        users
        .Where(u =>
            string.IsNullOrEmpty(searchText) ||
            (u.displayName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true) ||
            (u.email?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true)
        )
        .Where(u =>
            (!fromDate.HasValue || u.createdAt >= fromDate) &&
            (!toDate.HasValue || u.createdAt <= toDate)
        ).
        OrderBy(u => sortField switch
        {
            "displayName" => (object?)u.displayName,
            "email" => (object?)u.email,
            "createdAt" => u.createdAt,
            _ => u.createdAt
        });

    private IEnumerable<User> pagedUsers =>
        (sortAsc ? processedUsers : processedUsers.Reverse())
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize);

    private int totalPages =>
        (int)Math.Ceiling(processedUsers.Count() / (double)pageSize);

    private void Sort(string field)
    {
        if (sortField == field)
            sortAsc = !sortAsc;
        else
        {
            sortField = field;
            sortAsc = true;
        }
    }

    private void ApplyQuickFilter()
    {
        var now = DateTime.Now;

        switch (quickFilter)
        {
            case "week":
                fromDate = now.AddDays(-7);
                break;
            case "month":
                fromDate = new DateTime(now.Year, now.Month, 1);
                break;
            case "year":
                fromDate = new DateTime(now.Year, 1, 1);
                break;
            default:
                fromDate = null;
                toDate = null;
                break;
        }

        toDate = now;
        currentPage = 1;
    }

    private void NextPage() { if (currentPage < totalPages) currentPage++; }
    private void PrevPage() { if (currentPage > 1) currentPage--; }


    private async Task ConfirmToggleStatus(User user, string newStatus)
    {
        var action = newStatus == "locked" ? "khóa" : "mở";
        var ok = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn {action} tài khoản {user.displayName}?");

        if (!ok) return;

        await ToggleStatus(user, newStatus);
    }
    private async Task ToggleStatus(User user, string newStatus)
    {
        var res = await Http.PatchAsJsonAsync($"api/users/{user.uid}/status", newStatus);

        if (res.IsSuccessStatusCode)
        {
            user.status = newStatus;
            Layout?.ShowSuccess($"Đã cập nhật {user.displayName}");
        }
    }
}